{
  "name": "polymarket-telegram-alerts-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "deploy": "wrangler deploy",
    "dev": "node scripts/dev.mjs",
    "dev:local": "wrangler dev",
    "typecheck": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.test.json && node --experimental-specifier-resolution=node --test test/*.test.mjs",
    "webhook:dev": "node scripts/webhook.mjs dev",
    "webhook:prod": "node scripts/webhook.mjs prod",
    "db:migrate": "wrangler d1 execute polymarket-alerts --remote --file=./src/db/schema.sql",
    "db:migrate:local": "wrangler d1 execute polymarket-alerts --local --file=./src/db/schema.sql"
  },
  "dependencies": {
    "@grammyjs/menu": "^1.3.1",
    "@structbuild/sdk": "^0.6.5",
    "grammy": "^1.35.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.5.0"
  }
}
